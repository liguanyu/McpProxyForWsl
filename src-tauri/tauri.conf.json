{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "McpProxy",
  "version": "0.1.0",
  "identifier": "local.mcpproxy.tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "McpProxy",
        "label": "main",
        "width": 920,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
